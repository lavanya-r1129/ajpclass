public int[] fix34(int[] nums) {
  int j = 0;
  
  for (int i = 0; i < nums.length - 1; i++) {
    if (nums[i] == 3) {
      // Find a 4 that isn't already after a 3
      while (nums[j]!= 4 || (j > 0 && nums[j - 1] == 3)) {
        j++;
      }
      
      // Swap the 4 into position i+1
      int temp = nums[i + 1];
      nums[i + 1] = nums[j];
      nums[j] = temp;
    }
  }
  
  return nums;
}
