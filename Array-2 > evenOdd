public int[] evenOdd(int[] nums) {
  int[] result = new int[nums.length];
  int pos = 0;
  
  // First pass: evens
  for (int i = 0; i < nums.length; i++) {
    if (nums[i] % 2 == 0) {
      result[pos] = nums[i];
      pos++;
    }
  }
  
  // Second pass: odds
  for (int i = 0; i < nums.length; i++) {
    if (nums[i] % 2!= 0) {
      result[pos] = nums[i];
      pos++;
    }
  }
  
  return result;
}
