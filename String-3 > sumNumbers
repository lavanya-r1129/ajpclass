public int sumNumbers(String str) {
  int sum = 0;
  String num = "";
  
  for (int i = 0; i < str.length(); i++) {
    char c = str.charAt(i);
    
    if (Character.isDigit(c)) {
      num += c; // keep building the number
    } else {
      if (num.length() > 0) { // finished a number
        sum += Integer.parseInt(num);
        num = ""; // reset for next number
      }
    }
  }
  
  // Handle number at end of string
  if (num.length() > 0) {
    sum += Integer.parseInt(num);
  }
  
  return sum;
}
