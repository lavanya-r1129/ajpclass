public boolean gHappy(String str) {
  for (int i = 0; i < str.length(); i++) {
    if (str.charAt(i) == 'g') {
      boolean leftG = i > 0 && str.charAt(i - 1) == 'g';
      boolean rightG = i < str.length() - 1 && str.charAt(i + 1) == 'g';
      
      if (!leftG && !rightG) {
        return false; // found a lonely g
      }
    }
  }
  return true; // no lonely g's found
}
